{
  "name": "ts-rust-lib-template",
  "version": "0.0.0",
  "license": "ISC",
  "author": "Eric Haynes (https://github.com/ehaynes99)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "napi build --release --platform -o dist",
    "build:debug": "napi build --platform -o dist",
    "clean": "rm -rf ./dist",
    "format": "npm run lint -- --fix",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "napi": {
    "binaryName": "ts-rust-lib-template",
    "targets": []
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "@swc/core": "^1.12.7",
    "@swc/jest": "^0.2.38",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.6",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.0",
    "eslint-config-erich": "4.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
